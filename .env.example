# aido-proxy — API keys per provider
# Add keys with: aido-proxy add <key>
# Multiple keys are comma-separated (no spaces)

ZEN_KEYS=
OPENAI_KEYS=
ANTHROPIC_KEYS=
GROQ_KEYS=
GOOGLE_KEYS=

# Proxy settings
PROXY_PORT=4141
DEFAULT_PROVIDER=zen

# SQLite database path (default: ./aido.db)
# DB_PATH=./aido.db
